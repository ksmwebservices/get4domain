# Get4Domain Engineering Standard v1.0
# .gitignore — Root Level

# Environment
.env
.env.local
.env.*.local
.env.production

# Dependencies
node_modules/
*/node_modules/

# Build
dist/
build/
.next/
out/

# Logs
logs/
*.log

# Uploads (never commit client data)
uploads/*
!uploads/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/settings.json

# Testing
coverage/

# Prisma engines
**/.prisma/

# Docker override
docker-compose.override.yml

# Temp
tmp/
temp/
