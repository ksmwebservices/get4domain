# ============================================================
# GET4DOMAIN BACKEND — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub
# ============================================================

# ── Server ──
PORT=3008
FRONTEND_URL=https://get4domain.com

# ── Database (Supabase — use the POOLER connection, not direct) ──
DATABASE_URL=
DIRECT_URL=

# ── Auth ──
JWT_SECRET=

# ── Email (Resend) ──
RESEND_API_KEY=

# ── Payments (Razorpay) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Separate secret configured in the Razorpay dashboard webhook settings
RAZORPAY_WEBHOOK_SECRET=

# ── Claude API (for future AI features) ──
CLAUDE_API_KEY=

# ── Company Details (used on invoices) ──
COMPANY_NAME=KSM Quantum Technologies
COMPANY_GST=
COMPANY_PAN=
COMPANY_ADDRESS=
COMPANY_PHONE=+917550047567
COMPANY_EMAIL=admin@get4domain.com

# ── Admin ──
ADMIN_EMAIL=admin@get4domain.com
# Only used once by `npm run prisma:seed` to bootstrap the first SUPER_ADMIN account — not read at runtime
ADMIN_PASSWORD=
