# ============================================================
# GET4DOMAIN BACKEND — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub
# ============================================================

# ── Server ──
PORT=3008
FRONTEND_URL=https://get4domain.com

# ── Database (Supabase — use the POOLER connection, not direct) ──
DATABASE_URL=
DIRECT_URL=

# ── Auth ──
JWT_SECRET=

# ── Email (Resend) ──
RESEND_API_KEY=

# ── Payments (Razorpay) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Separate secret configured in the Razorpay dashboard webhook settings
RAZORPAY_WEBHOOK_SECRET=

# ── Claude API (for AI content/page generation) ──
CLAUDE_API_KEY=

# ── OpenAI (DALL-E image generation for AI content, optional) ──
OPENAI_API_KEY=

# ── Push Notifications (Firebase Cloud Messaging, service account) ──
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── SMS + WhatsApp (MSG91, DLT compliant) ──
MSG91_AUTH_KEY=
MSG91_SENDER_ID=G4DOMN
MSG91_WHATSAPP_NUMBER=
ADMIN_WHATSAPP_NUMBER=+917550047567

# ── Company Details (used on invoices) ──
COMPANY_NAME=KSM Quantum Technologies
COMPANY_GST=
COMPANY_PAN=
COMPANY_ADDRESS=
COMPANY_PHONE=+917550047567
COMPANY_EMAIL=admin@get4domain.com

# ── Admin ──
ADMIN_EMAIL=admin@get4domain.com
# Only used once by `npm run prisma:seed` to bootstrap the first SUPER_ADMIN account — not read at runtime
ADMIN_PASSWORD=
