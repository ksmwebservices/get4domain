# ============================================================
# GET4DOMAIN — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub
# ============================================================

# ── Backend API ──
# Admin and vendor accounts now live in the database (see backend-api) —
# login goes through the real API, not env-var credentials.
NEXT_PUBLIC_API_URL=https://gapi.get4domain.com

# ── Razorpay (public key only — used by Checkout.js on the billing page) ──
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Web Push (VAPID public key — pairs with backend VAPID_PRIVATE_KEY, generate with `npx web-push generate-vapid-keys`) ──
NEXT_PUBLIC_VAPID_KEY=

# ── Site URL ──
NEXT_PUBLIC_SITE_URL=https://get4domain.com

# ── Contact ──
NEXT_PUBLIC_PHONE=+919876543210
NEXT_PUBLIC_EMAIL=hello@get4domain.com
NEXT_PUBLIC_WHATSAPP=919876543210

# ── Google OAuth (optional - add when ready) ──
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# NEXTAUTH_SECRET=random-32-char-string
# NEXTAUTH_URL=https://get4domain.com
