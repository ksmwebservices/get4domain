{
  "platform": "Get4Domain",
  "version": "1.0.0",
  "status": "initialization",
  "website": "https://get4domain.com",
  "github": "https://github.com/ksmwebservices/get4domain",
  "engineeringStandard": "v1.0",
  "updated": "2025-07-04",

  "company": {
    "name": "Get4Domain",
    "type": "SaaS Managed Service",
    "model": "Low-cost Business Web Applications",
    "paymentPolicy": {
      "advance": "50%",
      "final": "50%",
      "rule": "No production deployment before full payment"
    },
    "sourceCodePolicy": "Not included in delivery unless separately contracted"
  },

  "techStack": {
    "frontend": ["Next.js", "TypeScript", "Tailwind CSS", "shadcn/ui"],
    "backend": ["NestJS", "TypeScript"],
    "database": "PostgreSQL",
    "orm": "Prisma",
    "auth": ["JWT", "Refresh Token", "RBAC"],
    "deployment": ["Docker", "Docker Compose", "Nginx"],
    "packageManager": "npm",
    "versionControl": "Git + GitHub"
  },

  "aiWorkflow": {
    "businessConsultantReviewer": {
      "tool": "ChatGPT",
      "responsibilities": ["Business Consultant", "Architecture Review", "Solution Review", "Prompt Engineering", "Final Approval"]
    },
    "engineer": {
      "tool": "Claude Code",
      "responsibilities": ["Engineering Package Generation", "Documentation", "Backend Development", "Integration", "Testing", "Deployment"]
    },
    "uiBuilder": {
      "tool": "Bolt",
      "responsibilities": ["Frontend UI"]
    }
  },

  "phases": {
    "P000": "Workspace Initialization (one-time)",
    "P001": "Client Project Initialization",
    "P002": "Bolt UI Development",
    "P003": "Backend Modules + APIs + Database",
    "P004": "Integration",
    "P005": "Testing + Build Verification",
    "P006": "Deployment"
  },

  "industryPacks": [
    "travel",
    "real-estate",
    "hospital",
    "school",
    "restaurant",
    "hr",
    "retail"
  ],

  "activeClients": [
    {
      "id": "MR_TRAVELS_001",
      "name": "M.R. Travels & Tours",
      "industry": "travel",
      "status": "P001-complete",
      "repo": "github.com/ksmwebservices/mr-travels-001",
      "devUrl": "mr-travels-dev.get4domain.com"
    }
  ],

  "environments": {
    "development": "{client}-dev.get4domain.com",
    "staging": "{client}-staging.get4domain.com",
    "production": "{client}.get4domain.com"
  },

  "branchStrategy": {
    "main": "Production only — protected",
    "develop": "Integration branch",
    "feature": "feature/{description}",
    "fix": "fix/{description}",
    "hotfix": "hotfix/{description}",
    "release": "release/{version}"
  }
